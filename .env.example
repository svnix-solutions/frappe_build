# Image built from this repo's Dockerfile (push to a registry Komodo can pull from)
FRAPPE_IMAGE=ghcr.io/your-org/frappe-app:latest

# Site
FRAPPE_SITE_NAME_HEADER=erp.example.com

# Public-facing domain(s) Caddy should serve this app on.
# Space-separated for multiple (Caddy treats them as a single site).
# Caddy auto-provisions HTTPS certs for any real public hostname.
PUBLIC_DOMAINS=erp.example.com

# Docker network shared with the caddy-docker-proxy stack. Must exist before
# `docker compose up` — create once on the host: `docker network create caddy`.
CADDY_NETWORK=caddy

# --- Database ---

# Where the app stack connects:
#   Single-host (DB on the same docker host):
#     DB_HOST=host.docker.internal
#   Multi-host (DB has been moved to its own server):
#     DB_HOST=10.0.0.5            (private IP on Tailscale / VPC / WireGuard)
DB_HOST=host.docker.internal
DB_PORT=3306

# MariaDB root password (required by compose.db.yaml)
DB_ROOT_PASSWORD=change-me

# MariaDB InnoDB buffer pool — rule of thumb: ~60-70% of host RAM dedicated to DB
INNODB_BUFFER_POOL_SIZE=1G

# Interface MariaDB binds on (compose.db.yaml only):
#   Single-host: 0.0.0.0  → MUST firewall 3306 off the public internet
#   Multi-host:  <private-IP-of-this-host>  → only the app server can reach it
DB_PUBLISH_BIND=0.0.0.0
DB_PUBLISH_PORT=3306

# --- JuiceFS (compose.jfs.yaml) ---
# The frappe-jfs stack mounts a JuiceFS volume on the host; the app stack
# bind-mounts that path as `sites/`. Bring frappe-jfs up before the app stack.

# Host directory the FUSE mount propagates to. The app stack reads from
# ${JFS_HOST_MOUNT}/${JFS_NAME}, so both stacks must agree on these.
JFS_HOST_MOUNT=/mnt/jfs
JFS_NAME=frappe-sites

# Redis password for the JuiceFS metadata DB. Losing this DB = losing the
# filesystem, even if every chunk is still in the object bucket. Back up the
# jfs-meta-data volume separately from the object store.
JFS_META_PASSWORD=change-me

# Local read cache size in MB. Bigger = fewer object-store round trips, more
# host disk used. Sized to roughly fit your hot file uploads / attachments.
JFS_CACHE_SIZE=10240

# Object storage backend. Any S3-compatible endpoint works (AWS S3, MinIO,
# Cloudflare R2, Backblaze B2, Wasabi, ...). For non-AWS S3, set --bucket to
# the full endpoint URL including the bucket name.
#   AWS S3:    https://s3.<region>.amazonaws.com/<bucket>
#   MinIO:     http://minio.internal:9000/<bucket>
#   R2:        https://<account-id>.r2.cloudflarestorage.com/<bucket>
JFS_STORAGE=s3
JFS_BUCKET=https://s3.us-east-1.amazonaws.com/your-bucket
JFS_ACCESS_KEY=change-me
JFS_SECRET_KEY=change-me
